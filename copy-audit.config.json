{
  "version": 1,
  "projectId": "sox",
  "rootDir": ".",
  "targets": [
    {
      "id": "react-source",
      "path": "frontend/src",
      "mode": "source",
      "extensions": [".ts", ".tsx"]
    },
    {
      "id": "static-fallback",
      "path": "index.html",
      "mode": "rendered-html",
      "extensions": [".html"]
    }
  ],
  "excludePaths": ["node_modules", "dist", "coverage"],
  "roleGates": [],
  "minDuplicateLength": 28,
  "retainedVisibleCopy": [],
  "additionalBannedPatterns": [
    {
      "id": "sox-page-tour",
      "description": "SOX 섹션 순서를 설명하는 문구",
      "pattern": "커버리지와 상위 종목을 먼저 확인합니다|상위 종목의 비중과 가격·실적 모멘텀을 비교합니다"
    }
  ]
}
